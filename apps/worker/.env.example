WORKER_NAME=detection-ai-worker
API_BASE_URL=http://localhost:8000/api/v1
API_INTERNAL_TOKEN=internal-local-token
SITE_ID=
CAMERA_ID=
CAMERA_SOURCE_TYPE=webcam
CAMERA_SOURCE=0
DETECTOR_TYPE=yolo
YOLO_MODEL=yolov8n.pt
FRAME_STRIDE=5
CONFIDENCE_THRESHOLD=0.55
ALERT_COOLDOWN_SECONDS=12
PREVIEW_OUTPUT_DIR=../../storage/live
SNAPSHOT_OUTPUT_DIR=../../storage/snapshots
FACE_MODEL_DIR=../../models/opencv
FACE_PROFILE_REFRESH_SECONDS=60
FACE_MATCH_THRESHOLD=0.45
ENABLE_POSE_POSTURE=true
POSE_MODEL=yolov8n-pose.pt
POSE_CONFIDENCE_THRESHOLD=0.5
HEAD_DOWN_THRESHOLD_SECONDS=8
FALL_THRESHOLD_SECONDS=3
INACTIVITY_THRESHOLD_SECONDS=20
INACTIVITY_MOVEMENT_THRESHOLD_PX=24
